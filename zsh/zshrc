setopt prompt_subst
setopt no_beep
setopt interactive_comments
setopt hist_ignore_all_dups
setopt hist_reduce_blanks
setopt hist_save_no_dups
setopt inc_append_history
setopt share_history

export HISTFILE="${HISTFILE:-${XDG_STATE_HOME:-$HOME/.local/state}/zsh/history}"
export HISTSIZE="${HISTSIZE:-32768}"
export SAVEHIST="${SAVEHIST:-32768}"
mkdir -p "${HISTFILE:h}" "${XDG_CACHE_HOME:-$HOME/.cache}/zsh"

zsh_add_file() {
  [[ -r "$1" ]] && source "$1"
}

zsh_load_antidote() {
  local antidote_file
  for antidote_file in \
    "$HOMEBREW_PREFIX/opt/antidote/share/antidote/antidote.zsh" \
    "/opt/homebrew/opt/antidote/share/antidote/antidote.zsh" \
    "/usr/local/opt/antidote/share/antidote/antidote.zsh" \
    "/usr/share/zsh-antidote/antidote.zsh"
  do
    if [[ -r "$antidote_file" ]]; then
      source "$antidote_file"
      return 0
    fi
  done
  return 1
}

fpath=("$HOME/.zfunc" $fpath)

if zsh_load_antidote; then
  zsh_plugins="${DOTFILES_DIR:-$HOME/Code/dot}/zsh/plugins.txt"
  zsh_plugins_static="${XDG_CACHE_HOME:-$HOME/.cache}/zsh/plugins.zsh"
  if [[ -r "$zsh_plugins" && ( ! -s "$zsh_plugins_static" || "$zsh_plugins" -nt "$zsh_plugins_static" ) ]]; then
    antidote bundle < "$zsh_plugins" >| "$zsh_plugins_static"
  fi
  zsh_add_file "$zsh_plugins_static"
fi

autoload -Uz compinit
zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'
zstyle ':completion:*' special-dirs true
compinit -d "${XDG_CACHE_HOME:-$HOME/.cache}/zsh/zcompdump-${ZSH_VERSION}"

for file in "${DOTFILES_DIR:-$HOME/Code/dot}"/zsh/lib/*.zsh; do
  zsh_add_file "$file"
done
unset file

case "$(uname -s)" in
  Darwin) zsh_add_file "${DOTFILES_DIR:-$HOME/Code/dot}/zsh/os/darwin.zsh" ;;
  Linux) zsh_add_file "${DOTFILES_DIR:-$HOME/Code/dot}/zsh/os/linux.zsh" ;;
esac

if command -v mise >/dev/null 2>&1; then
  eval "$(mise activate zsh)"
elif [[ -d "$VOLTA_HOME" ]]; then
  path=("$VOLTA_HOME/bin" $path)
fi

command -v zoxide >/dev/null 2>&1 && eval "$(zoxide init zsh)"
command -v atuin >/dev/null 2>&1 && eval "$(atuin init zsh)"

if command -v starship >/dev/null 2>&1; then
  eval "$(starship init zsh)"
else
  PROMPT='%F{green}%n@%m%f %F{blue}%~%f %# '
fi

for file in \
  "$XDG_CONFIG_HOME/dot/zshrc.zsh" \
  "$XDG_CONFIG_HOME/dot/work.zsh" \
  "$XDG_CONFIG_HOME/dot/hosts/${HOST%%.*}.zsh" \
  "${DOTFILES_DIR:-$HOME/Code/dot}/zsh/zshrc.local"
do
  zsh_add_file "$file"
done
unset file zsh_plugins zsh_plugins_static
unfunction zsh_add_file zsh_load_antidote
